{
  "manifest_version": 3,
  "name": "TIC:)",
  "version": "1.0",
  "description": "Adds shit for ORT campus.",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://campus.ort.edu.ar/*"],
      "js": [
        "defaultNameMap.js",
        "nameMap.js",
        "managerLink.js",
        "content.js"
      ]
    }
  ],
  "permissions": ["activeTab", "storage"]
}
